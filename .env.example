# 复制本文件为 .env 并填入真实值:  cp .env.example .env
# .env 已被 .gitignore 忽略,绝不会提交。切勿把真实 key 写进 .env.example。

# ===== LLM:DashScope(通义千问) =====
DASHSCOPE_API_KEY=sk-在这里填你的新key
# 抽取/决策用的模型名(按需调整)
LLM_MODEL=qwen-max
LLM_MODEL_SMALL=qwen-turbo

# ===== Embedding =====
# local = 本地 bge-m3(默认,零成本);dashscope = 调通义 text-embedding-v3
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_LOCAL=BAAI/bge-m3
EMBEDDING_MODEL_DASHSCOPE=text-embedding-v3

# ===== 重排 Cross-Encoder(本地) =====
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ===== NLI 蕴含模型(本地,IsSup 用)=====
# 留空:IsSup 走 LLM 兜底(每次调 DashScope,慢且贵)
# 配置后:本地推理,便宜可量化。推荐多语 mDeBERTa(279M,支持中文,三类输出)。
# 首次使用会从 HF Hub 下载约 1.1GB 模型;若访问慢,可先手动下到本地缓存。
NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-xnli-multilingual-nli-2mil7

# ===== HuggingFace:强制离线(模型已在本地缓存,无需联网检查更新) =====
# 消除启动时的 "unauthenticated requests" warning,也防止网络抖动导致加载崩溃
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ===== Neo4j(docker-compose 起的本地实例) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123

# ===== Qdrant(docker-compose 起的本地实例) =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=graphrag_chunks
